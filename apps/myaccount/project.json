{
    "name": "myaccount",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "apps/myaccount/src",
    "projectType": "application",
    "generators": {},
    "prefix": "@wso2is",
    "tags": [],
    "implicitDependencies": [
        "access-control",
        "core",
        "forms",
        "i18n",
        "react-components",
        "theme",
        "validation"
    ],
    "targets": {
        "build-prepare": {
            "executor": "nx:run-commands",
            "options": {
                "commands": [
                    {
                        "command": "pnpm prebuild",
                        "description": "Preparing the build copying necessary assets, etc."
                    }
                ],
                "cwd": "apps/myaccount",
                "parallel": false
            }
        },
        "build-base": {
            "executor": "nx:run-commands",
            "outputs": [
                "{workspaceRoot}/apps/myaccount/build/myaccount"
            ],
            "options": {
                "commands": [
                    {
                        "command": "pnpm vite build --config vite.config.ts --mode production",
                        "description": "Build the My Account app using Vite."
                    },
                    {
                        "command": "node scripts/build/assemble-vite-build.js",
                        "description": "Assemble My Account deployable artifacts around Vite output."
                    }
                ],
                "cwd": "apps/myaccount",
                "parallel": false
            }
        },
        "build-windup": {
            "executor": "nx:run-commands",
            "options": {
                "commands": [
                    {
                        "command": "pnpm postbuild",
                        "description": "Clearing up the redundant files after the build."
                    }
                ],
                "cwd": "apps/myaccount",
                "parallel": false
            }
        },
        "build": {
            "executor": "nx:run-commands",
            "outputs": ["{workspaceRoot}/apps/myaccount/build/myaccount"],
            "options": {
                "commands": [
                    "pnpm nx run myaccount:build-prepare",
                    "pnpm nx run myaccount:build-base",
                    "pnpm nx run myaccount:build-windup"
                ],
                "cwd": "apps/myaccount",
                "parallel": false
            }
        },
        "clean": {
            "executor": "nx:run-commands",
            "options": {
                "commands": [
                    {
                        "command": "pnpm clean",
                        "description": "Cleaning My Account"
                    }
                ],
                "cwd": "apps/myaccount",
                "parallel": false
            }
        },
        "serve-prepare": {
            "executor": "nx:run-commands",
            "options": {
                "commands": [
                    {
                        "command": "pnpm prebuild",
                        "description": "Preparing for the serve copying necessary assets, etc."
                    }
                ],
                "cwd": "apps/myaccount",
                "parallel": true
            }
        },
        "serve-base": {
            "executor": "nx:run-commands",
            "options": {
                "commands": [
                    {
                        "command": "pnpm vite --config vite.config.ts --mode development",
                        "description": "Serve the My Account app using Vite dev server."
                    }
                ],
                "cwd": "apps/myaccount",
                "parallel": false
            }
        },
        "serve": {
            "executor": "nx:run-commands",
            "options": {
                "commands": [
                    "pnpm nx run myaccount:serve-prepare",
                    "pnpm nx run myaccount:serve-base"
                ],
                "cwd": "apps/myaccount",
                "parallel": false
            }
        },
        "lint": {
            "executor": "nx:run-commands",
            "options": {
                "command": "pnpm lint",
                "cwd": "apps/myaccount",
                "parallel": false
            }
        },
        "test": {
            "executor": "nx:run-commands",
            "options": {
                "command": "pnpm test",
                "cwd": "apps/myaccount",
                "parallel": false
            }
        },
        "test-coverage": {
            "executor": "nx:run-commands",
            "options": {
                "command": "pnpm test:coverage",
                "cwd": "apps/myaccount",
                "parallel": false
            }
        }
    }
}
