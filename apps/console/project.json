{
    "name": "console",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "apps/console/src",
    "projectType": "application",
    "generators": {},
    "prefix": "@wso2is",
    "tags": [],
    "implicitDependencies": [
        "access-control",
        "core",
        "form",
        "forms",
        "i18n",
        "react-components",
        "theme",
        "validation"
    ],
    "targets": {
        "build-prepare": {
            "executor": "nx:run-commands",
            "options": {
                "commands": [
                    {
                        "command": "pnpm prebuild",
                        "description": "Preparing the build copying necessary assets, etc."
                    }
                ],
                "cwd": "apps/console",
                "parallel": false
            }
        },
        "build-base": {
            "executor": "nx:run-commands",
            "outputs": [
                "{workspaceRoot}/apps/console/build/console"
            ],
            "options": {
                "commands": [
                    {
                        "command": "pnpm vite build --config vite.config.ts --mode production",
                        "description": "Build the Console app using Vite."
                    },
                    {
                        "command": "node scripts/build/assemble-vite-build.js",
                        "description": "Assemble Console deployable artifacts around Vite output."
                    }
                ],
                "cwd": "apps/console",
                "parallel": false
            }
        },
        "build-windup": {
            "executor": "nx:run-commands",
            "options": {
                "commands": [
                    {
                        "command": "pnpm postbuild",
                        "description": "Clearing up the redundant files after the build."
                    }
                ],
                "cwd": "apps/console",
                "parallel": false
            }
        },
        "build": {
            "executor": "nx:run-commands",
            "outputs": ["{workspaceRoot}/apps/console/build/console"],
            "options": {
                "commands": [
                    "pnpm nx run console:build-prepare",
                    "pnpm nx run console:build-base",
                    "pnpm nx run console:build-windup"
                ],
                "cwd": "apps/console",
                "parallel": false
            }
        },
        "clean": {
            "executor": "nx:run-commands",
            "options": {
                "commands": [
                    {
                        "command": "pnpm clean",
                        "description": "Cleaning Console"
                    }
                ],
                "cwd": "apps/console",
                "parallel": false
            }
        },
        "serve-prepare": {
            "executor": "nx:run-commands",
            "options": {
                "commands": [
                    {
                        "command": "pnpm prebuild",
                        "description": "Preparing for the serve copying necessary assets, etc."
                    }
                ],
                "cwd": "apps/console",
                "parallel": true
            }
        },
        "serve-base": {
            "executor": "nx:run-commands",
            "options": {
                "commands": [
                    {
                        "command": "pnpm vite --config vite.config.ts --mode development",
                        "description": "Serve the Console app using Vite dev server."
                    }
                ],
                "cwd": "apps/console",
                "parallel": false
            }
        },
        "serve": {
            "executor": "nx:run-commands",
            "options": {
                "commands": [
                    "pnpm nx run console:serve-prepare",
                    "pnpm nx run console:serve-base"
                ],
                "cwd": "apps/console",
                "parallel": false
            }
        },
        "lint": {
            "executor": "nx:run-commands",
            "options": {
                "command": "pnpm lint",
                "cwd": "apps/console",
                "parallel": false
            }
        },
        "test": {
            "executor": "nx:run-commands",
            "options": {
                "command": "pnpm test",
                "cwd": "apps/console",
                "parallel": false
            }
        },
        "test-coverage": {
            "executor": "nx:run-commands",
            "options": {
                "command": "pnpm test:coverage",
                "cwd": "apps/console",
                "parallel": false
            }
        }
    }
}
